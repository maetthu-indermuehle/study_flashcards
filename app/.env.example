DATABASE_URL="postgresql://ppl_flashcards:ppl_flashcards@localhost:5432/ppl_flashcards?schema=public"
PORT=3000

# Seed script credentials — used by `prisma db seed` to create the default user.
# In local development these are set in docker-compose.yml; only needed here
# when running the seed manually outside of Docker.
SEED_USER_EMAIL="admin@local.dev"
SEED_USER_PASSWORD="localdev"
